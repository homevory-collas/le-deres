# ─── Database ───────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ledesir"

# ─── Auth (replace with NextAuth / Clerk in Phase 2) ──
NEXTAUTH_SECRET="replace-with-random-secret"
